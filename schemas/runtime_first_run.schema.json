{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "datalens.delta_v8.runtime_first_run.schema.json",
  "title": "DataLens Delta v8 Runtime First Run",
  "type": "object",
  "required": ["schema_version", "target", "mode", "status", "validation_budget", "runtime_smoke"],
  "properties": {
    "schema_version": {"const": "datalens.delta_v8.runtime_first_run.v1"},
    "target": {
      "type": "object",
      "properties": {
        "workbook_id": {"type": "string"},
        "dashboard_id": {"type": "string"},
        "tab_id": {"type": "string"},
        "object_ids": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "mode": {"enum": ["quick_visible_patch", "dataset_sql_patch", "source_availability_patch", "full_audit"]},
    "status": {"enum": ["runtime_passed", "runtime_failed", "runtime_not_verified", "blocked_before_write", "structural_ok_runtime_not_checked"]},
    "validation_budget": {
      "type": "object",
      "required": ["required_gates", "skipped_gates"],
      "properties": {
        "required_gates": {"type": "array", "items": {"type": "string"}},
        "skipped_gates": {"type": "array", "items": {"type": "object"}},
        "elapsed_seconds": {"type": "number"}
      }
    },
    "runtime_smoke": {"$ref": "browser_runtime_smoke.schema.json"},
    "artifact_paths": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
