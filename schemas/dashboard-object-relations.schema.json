{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/datalens-dev-mcp/schemas/dashboard-object-relations.schema.json",
  "title": "Dashboard object relations",
  "type": "object",
  "required": ["schema_version", "dashboard", "layout_blueprint", "tabs", "widgets", "charts", "selectors"],
  "properties": {
    "schema_version": {"type": "string"},
    "dashboard": {
      "type": "object",
      "required": ["dashboard_id_placeholder", "name", "dashboard_type"],
      "properties": {
        "dashboard_id_placeholder": {"type": "string"},
        "name": {"type": "string"},
        "dashboard_type": {"type": "string"}
      },
      "additionalProperties": true
    },
    "layout_blueprint": {
      "type": "object",
      "required": ["dashboard_type", "selector_zone", "content_flow", "selector_row_width", "native_metadata_required"],
      "properties": {
        "dashboard_type": {"type": "string"},
        "selector_zone": {"type": "string"},
        "content_flow": {"type": "array", "items": {"type": "string"}},
        "selector_row_width": {"const": "94%"},
        "native_metadata_required": {"const": true}
      },
      "additionalProperties": true
    },
    "tabs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tab_id", "title", "widgets"],
        "properties": {
          "tab_id": {"type": "string"},
          "title": {"type": "string"},
          "widgets": {"type": "array", "items": {"type": "string"}},
          "relation": {"const": "tab_to_widget"}
        },
        "additionalProperties": true
      }
    },
    "widgets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["widget_id", "object_id_placeholder", "tab_id", "layout"],
        "properties": {
          "widget_id": {"type": "string"},
          "object_id_placeholder": {"type": "string"},
          "tab_id": {"type": "string"},
          "chart_id": {"type": "string"},
          "selector_id": {"type": "string"},
          "route": {"type": "string"},
          "native_metadata": {"$ref": "#/$defs/native_metadata"},
          "layout": {
            "type": "object",
            "required": ["x", "y", "w", "h", "width"],
            "properties": {
              "x": {"type": "number"},
              "y": {"type": "number"},
              "w": {"type": "number"},
              "h": {"type": "number"},
              "width": {"type": "string", "pattern": "^[1-9][0-9]?%$"}
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "charts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chart_id", "widget_id", "route", "dataset_dependencies", "field_dependencies"],
        "properties": {
          "chart_id": {"type": "string"},
          "widget_id": {"type": "string"},
          "family": {"type": "string"},
          "route": {"type": "string"},
          "native_metadata": {"$ref": "#/$defs/native_metadata"},
          "dataset_dependencies": {"type": "array", "items": {"type": "string"}},
          "field_dependencies": {"type": "array", "items": {"type": "string"}},
          "calculated_field_dependencies": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "chart_relations": {"type": "array", "items": {"type": "object"}},
    "navigation_relations": {"type": "array", "items": {"type": "object"}},
    "selectors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["selector_id", "param", "labelPlacement", "width", "targets"],
        "properties": {
          "selector_id": {"type": "string"},
          "param": {"type": "string"},
          "labelPlacement": {"const": "left"},
          "width": {"type": "string", "pattern": "^[1-9][0-9]?%$"},
          "source_field": {"type": "string"},
          "targets": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["target_id", "target_kind", "param"],
              "properties": {
                "target_id": {"type": "string"},
                "target_kind": {"enum": ["widget", "chart"]},
                "param": {"type": "string"}
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "dashboard_filters": {"type": "array", "items": {"type": "object"}},
    "datasets": {"type": "array", "items": {"type": "object"}}
  },
  "$defs": {
    "native_metadata": {
      "type": "object",
      "required": ["title", "hideTitle", "enableHint"],
      "properties": {
        "title": {"type": "string"},
        "hint": {"type": "string"},
        "hideTitle": {"const": false},
        "enableHint": {"const": true}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
