{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "datalens.browser_capture.schema.json",
  "title": "Machine-readable DataLens browser capture",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "status",
    "captured_at",
    "target_url",
    "tab_id",
    "branch",
    "object_revisions",
    "changed_object_ids",
    "checked_selectors",
    "selector_interaction",
    "scroll_check",
    "visible_widget_titles",
    "console_messages",
    "dom_error_texts",
    "console_error_count"
  ],
  "properties": {
    "schema_version": {
      "enum": [
        "datalens.browser_capture.v1",
        "datalens.browser_capture.v2",
        "datalens.browser_capture.v3"
      ]
    },
    "status": {"const": "passed"},
    "captured_at": {"type": "string", "format": "date-time"},
    "target_url": {"type": "string", "format": "uri", "minLength": 1},
    "tab_id": {"type": "string", "minLength": 1},
    "branch": {"enum": ["saved", "published"]},
    "revision_id": {"type": "string", "minLength": 1},
    "object_revisions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "changed_object_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "checked_selectors": {
      "type": "array",
      "items": {"$ref": "#/$defs/checkedSelector"}
    },
    "selector_interaction": {"$ref": "#/$defs/selectorInteraction"},
    "scroll_check": {"$ref": "#/$defs/scrollCheck"},
    "visible_widget_titles": {"type": "array", "items": {"type": "string"}},
    "body_text_excerpt": {"type": "string"},
    "console_messages": {"type": "array", "items": {"type": "string"}},
    "dom_error_texts": {"type": "array", "items": {"type": "string"}},
    "marker_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "console_error_count": {"type": "integer", "minimum": 0},
    "image_artifact": {"$ref": "#/$defs/imageArtifact"},
    "change_scope": {"enum": ["content", "layout", "dashboard"]},
    "viewport_checks": {
      "type": "array",
      "items": {"$ref": "#/$defs/viewportCheck"}
    }
  },
  "$defs": {
    "imageArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "scopeObjectIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "checkedSelector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selector_id", "interaction", "status", "affected_object_ids"],
      "properties": {
        "selector_id": {"type": "string", "minLength": 1},
        "interaction": {"type": "string", "minLength": 1},
        "status": {"const": "passed"},
        "affected_object_ids": {"$ref": "#/$defs/scopeObjectIds"},
        "selected_value": {}
      }
    },
    "selectorInteraction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "scope_object_ids"],
      "properties": {
        "status": {"enum": ["passed", "not_applicable"]},
        "scope_object_ids": {"$ref": "#/$defs/scopeObjectIds"},
        "reason": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "detail"],
          "properties": {
            "code": {
              "enum": [
                "no_selectors_in_scope",
                "selectors_not_affected_by_change",
                "target_is_non_interactive"
              ]
            },
            "detail": {"type": "string", "minLength": 1}
          }
        }
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "not_applicable"}}},
          "then": {"required": ["reason"]}
        }
      ]
    },
    "scrollCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "scope_object_ids", "document_height", "viewport_height"],
      "properties": {
        "status": {"enum": ["passed", "not_applicable"]},
        "scope_object_ids": {"$ref": "#/$defs/scopeObjectIds"},
        "document_height": {"type": "number", "exclusiveMinimum": 0},
        "viewport_height": {"type": "number", "exclusiveMinimum": 0},
        "start_scroll_y": {"type": "number", "minimum": 0},
        "end_scroll_y": {"type": "number", "minimum": 0},
        "bottom_reached": {"type": "boolean"},
        "reason": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "detail"],
          "properties": {
            "code": {"const": "content_fits_viewport"},
            "detail": {"type": "string", "minLength": 1}
          }
        }
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "passed"}}},
          "then": {
            "required": ["start_scroll_y", "end_scroll_y", "bottom_reached"],
            "properties": {"bottom_reached": {"const": true}}
          }
        },
        {
          "if": {"properties": {"status": {"const": "not_applicable"}}},
          "then": {"required": ["reason"]}
        }
      ]
    },
    "viewportCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "device_pixel_ratio",
        "document_width",
        "horizontal_overflow_px",
        "scope_object_ids",
        "visible_object_ids",
        "clipped_object_ids",
        "missing_object_ids",
        "screenshot_artifact"
      ],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "width": {"type": "number", "exclusiveMinimum": 0},
        "height": {"type": "number", "exclusiveMinimum": 0},
        "device_pixel_ratio": {"type": "number", "exclusiveMinimum": 0},
        "document_width": {"type": "number", "exclusiveMinimum": 0},
        "horizontal_overflow_px": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "scope_object_ids": {"$ref": "#/$defs/scopeObjectIds"},
        "visible_object_ids": {"$ref": "#/$defs/scopeObjectIds"},
        "clipped_object_ids": {
          "type": "array",
          "maxItems": 0,
          "items": {"type": "string", "minLength": 1}
        },
        "missing_object_ids": {
          "type": "array",
          "maxItems": 0,
          "items": {"type": "string", "minLength": 1}
        },
        "truncated_text_object_ids": {
          "type": "array",
          "maxItems": 0,
          "items": {"type": "string", "minLength": 1}
        },
        "overlap_pairs": {
          "type": "array",
          "maxItems": 0,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["first_object_id", "second_object_id"],
            "properties": {
              "first_object_id": {"type": "string", "minLength": 1},
              "second_object_id": {"type": "string", "minLength": 1}
            }
          }
        },
        "screenshot_artifact": {"$ref": "#/$defs/imageArtifact"}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {"const": "datalens.browser_capture.v1"}
        }
      },
      "then": {
        "required": ["image_artifact"]
      }
    },
    {
      "if": {
        "properties": {
          "schema_version": {
            "enum": [
              "datalens.browser_capture.v2",
              "datalens.browser_capture.v3"
            ]
          }
        }
      },
      "then": {
        "required": ["change_scope", "viewport_checks"],
        "allOf": [
          {
            "if": {
              "properties": {
                "change_scope": {"const": "content"}
              }
            },
            "then": {
              "properties": {
                "viewport_checks": {"minItems": 1}
              }
            }
          },
          {
            "if": {
              "properties": {
                "change_scope": {"enum": ["layout", "dashboard"]}
              }
            },
            "then": {
              "properties": {
                "viewport_checks": {
                  "minItems": 2,
                  "allOf": [
                    {
                      "contains": {
                        "type": "object",
                        "required": ["width"],
                        "properties": {
                          "width": {"maximum": 1280}
                        }
                      },
                      "minContains": 1
                    },
                    {
                      "contains": {
                        "type": "object",
                        "required": ["width"],
                        "properties": {
                          "width": {"minimum": 1366}
                        }
                      },
                      "minContains": 1
                    }
                  ]
                }
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "schema_version": {"const": "datalens.browser_capture.v3"}
        }
      },
      "then": {
        "properties": {
          "viewport_checks": {
            "items": {
              "required": [
                "truncated_text_object_ids",
                "overlap_pairs"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selector_interaction": {
            "properties": {"status": {"const": "passed"}}
          }
        }
      },
      "then": {"properties": {"checked_selectors": {"minItems": 1}}}
    },
    {
      "if": {
        "properties": {
          "selector_interaction": {
            "properties": {"status": {"const": "not_applicable"}}
          }
        }
      },
      "then": {"properties": {"checked_selectors": {"maxItems": 0}}}
    }
  ]
}
