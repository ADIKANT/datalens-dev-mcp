{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/datalens-dev-mcp/schemas/calculated-field-config.schema.json",
  "title": "Calculated field config",
  "type": "object",
  "required": ["name", "role", "expression", "dependencies"],
  "properties": {
    "name": {"type": "string"},
    "title": {"type": "string"},
    "role": {"enum": ["dimension", "measure", "parameter"]},
    "expression": {"type": "string"},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "aggregation": {"type": "string"},
    "unit": {"type": "string"},
    "description": {"type": "string"}
  },
  "additionalProperties": true
}
