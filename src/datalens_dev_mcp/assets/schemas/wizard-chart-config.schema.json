{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/datalens-dev-mcp/schemas/wizard-chart-config.schema.json",
  "title": "Wizard native chart compiler input",
  "type": "object",
  "required": ["visualization_id", "dataset", "field_bindings"],
  "properties": {
    "schema_version": {"type": "string"},
    "route": {"enum": ["wizard_native", "wizard_map_native"]},
    "visualization_id": {"enum": ["metric", "flatTable", "pivotTable", "line", "area", "area100p", "column", "column100p", "bar", "bar100p", "combined-chart", "pie", "donut", "scatter", "treemap", "geolayer"]},
    "semantic_family": {"type": "string"},
    "widget_id": {"type": "string"},
    "dataset": {
      "oneOf": [
        {"type": "string", "minLength": 1},
        {"type": "object", "minProperties": 1}
      ]
    },
    "location": {
      "oneOf": [
        {"type": "object", "required": ["key"], "properties": {"key": {"type": "string", "minLength": 1}}, "not": {"anyOf": [{"required": ["workbookId"]}, {"required": ["name"]}]}},
        {"type": "object", "required": ["workbookId", "name"], "properties": {"workbookId": {"type": "string", "minLength": 1}, "name": {"type": "string", "minLength": 1}}, "not": {"required": ["key"]}}
      ]
    },
    "field_bindings": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {"type": "string", "minLength": 1},
          {"type": "object", "minProperties": 1},
          {"type": "array", "minItems": 1, "items": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "object", "minProperties": 1}]}}
        ]
      }
    },
    "options": {"type": "object"},
    "geo": {
      "type": "object",
      "properties": {
        "field": {"type": "string"},
        "evidence_kind": {"enum": ["geopoint", "geopolygon", "lat_lon", "validated_map_payload"]},
        "latitude_field": {"type": "string"},
        "longitude_field": {"type": "string"}
      }
    },
    "saved_seed": {"type": "object"},
    "annotation": {"type": "object"}
  },
  "allOf": [
    {
      "if": {"properties": {"route": {"const": "wizard_map_native"}}},
      "then": {"properties": {"visualization_id": {"const": "geolayer"}}}
    },
    {
      "if": {"properties": {"semantic_family": {"const": "bubble"}}},
      "then": {"properties": {"field_bindings": {"required": ["size"]}}}
    }
  ],
  "additionalProperties": true
}
