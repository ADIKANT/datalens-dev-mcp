{
  "schema_version": "2026-07-15.delivery_intent_state_machine.v3",
  "states": [
    "read_only",
    "plan_only",
    "save_only",
    "save_then_publish",
    "publish_from_saved",
    "blocked"
  ],
  "task_intents": {
    "read_only": ["review", "audit", "diagnose", "inspect", "unknown"],
    "plan_only": ["plan", "dry_run"],
    "delivery": ["implement", "fix", "enhance", "redesign", "update"]
  },
  "user_opt_out_overrides": ["draft", "save_only", "no_publish", "plan_only", "dry_run"],
  "request_authorization": {
    "standard_mutations": ["create", "update", "save", "publish_from_saved"],
    "source": "current_user_request",
    "delete_confirmation_parameter": "confirm_delete",
    "unsupported_mutations": ["move", "permissions", "credentials"]
  },
  "required_gates": {
    "save_only": [
      "target_lock",
      "writes_enabled",
      "save_enabled",
      "user_request_authorization",
      "fresh_readback",
      "revision_preservation",
      "saved_readback"
    ],
    "save_then_publish": [
      "target_lock",
      "writes_enabled",
      "save_enabled",
      "publish_enabled",
      "user_request_authorization",
      "fresh_readback",
      "revision_preservation",
      "saved_readback_fresh",
      "published_readback"
    ],
    "publish_from_saved": [
      "target_lock",
      "writes_enabled",
      "save_enabled",
      "publish_enabled",
      "user_request_authorization",
      "fresh_readback",
      "revision_preservation",
      "saved_readback_fresh",
      "published_readback"
    ]
  },
  "delivery_sequence": {
    "save_then_publish": ["save", "saved_readback", "publish_from_saved", "published_readback"],
    "publish_source": "fresh_saved_branch_readback"
  },
  "policy_text": "A live implementation, fix, enhance, redesign, or update request authorizes guarded save and publish for a locked target. The server performs fresh read, revision-preserving save, saved readback, publish from saved readback, and published readback without another confirmation. Only deletion of whole DataLens objects uses the confirm_delete flow."
}
