{
  "params_contracts": {
    "editor_advanced_metric_params": {
      "contract_id": "editor_advanced_metric_params",
      "params": [
        {
          "default": [
            "all"
          ],
          "name": "segment",
          "required": false,
          "type": "string[]"
        }
      ],
      "rule": "Params stay generic; business filters belong in dashboard wiring or explicit source contracts."
    },
    "editor_js_control_params": {
      "contract_id": "editor_js_control_params",
      "params": [
        {
          "default": [
            "all"
          ],
          "name": "segment",
          "required": false,
          "type": "string[]"
        }
      ],
      "rule": "Control params are selector parameters and must be wired outside the control body."
    },
    "editor_markdown_params": {
      "contract_id": "editor_markdown_params",
      "params": [
        {
          "default": "overview",
          "name": "section",
          "required": false,
          "type": "string"
        }
      ],
      "rule": "Markdown params select generic sections only."
    },
    "editor_table_params": {
      "contract_id": "editor_table_params",
      "params": [
        {
          "default": [
            "all"
          ],
          "name": "segment",
          "required": false,
          "type": "string[]"
        }
      ],
      "rule": "Table params may filter synthetic rows but must not encode business object ids."
    },
    "wizard_map_params": {
      "contract_id": "wizard_map_params",
      "params": [
        {
          "default": [
            "all"
          ],
          "name": "environment",
          "required": false,
          "type": "string[]"
        }
      ],
      "rule": "Wizard geolayer params require validated geo evidence and a canonical template or fresh same-ID saved seed."
    }
  },
  "policy_basis": [
    "AGENTS.md",
    "docs/route-policy.md",
    "config/route_selection_policy_v5.json",
    "src/datalens_dev_mcp/pipeline/route_contract.py",
    "templates/datalens/wizard/wizard_template_registry.json"
  ],
  "route_inventory": {
    "banned": [
      {
        "reason": "Outside the local safety model.",
        "route": "d3_node"
      },
      {
        "methods": [
          "deleteQLChart"
        ],
        "reason": "QL delete remains closed.",
        "route": "ql_delete"
      },
      {
        "reason": "QL is explicit-only.",
        "route": "automatic_ql_selection"
      },
      {
        "reason": "Route selection is deterministic before transport.",
        "route": "runtime_route_fallback"
      },
      {
        "reason": "Writes to guessed IDs are blocked.",
        "route": "guessed_id_write"
      },
      {
        "reason": "Fresh readback and the runtime write gates are required.",
        "route": "blind_write_or_publish"
      },
      {
        "reason": "Golden gallery is static and never mutates production.",
        "route": "production_workbook_mutation"
      }
    ],
    "reference_only": [
      {
        "reason": "Legacy HTML template remains blocked by the runtime validator.",
        "route": "grouped_sticky_table_exception"
      },
      {
        "reason": "Unknown IDs may be updated only from fresh saved readback and cannot be created.",
        "route": "unknown_wizard_visualization"
      }
    ],
    "supported": [
      {
        "do_not_change_runtime_contract": [
          "Prefer a fresh saved seed of the same visualization id.",
          "Never fall back to JS after a failed Wizard request."
        ],
        "entry_type": "wizard_chart",
        "families": [
          "area_100p",
          "area_completion",
          "bubble",
          "combo_time_series_combo",
          "donut",
          "flat_table",
          "grouped_bar",
          "horizontal_bar",
          "horizontal_stacked_100",
          "kpi_value_delta",
          "kpi_value_only",
          "line_chart",
          "multiline_chart",
          "native_map_geo_widget",
          "pie",
          "pivot_table",
          "pivot_table_node",
          "scatter",
          "stacked_100",
          "table_node",
          "treemap",
          "vertical_bar_time_bucket"
        ],
        "generator": "build_wizard_payload_plan",
        "known_limits": [
          "Unknown visualization IDs are blocked for create.",
          "Live verification is not claimed by canonical fixtures."
        ],
        "methods": {
          "create": "createWizardChart",
          "read": "getWizardChart",
          "update": "updateWizardChart"
        },
        "route": "wizard_native"
      },
      {
        "do_not_change_runtime_contract": [
          "Keep one visual per object and the Advanced Editor runtime allowlist."
        ],
        "entry_type": "advanced-chart_node",
        "families": [
          "box_plot",
          "bullet_assignees",
          "funnel_snapshot",
          "heatmap",
          "histogram",
          "kpi_value_delta_sparkline",
          "kpi_value_sparkline",
          "resource_schedule_exception",
          "sankey_status_flow",
          "table_pivot_js",
          "waterfall"
        ],
        "generator": "generate_editor_bundle",
        "known_limits": [
          "Selected only by direct request or registered capability gap."
        ],
        "methods": {
          "create": "createEditorChart",
          "read": "getEditorChart",
          "update": "updateEditorChart"
        },
        "route": "editor_advanced"
      },
      {
        "do_not_change_runtime_contract": [
          "Ordinary flat and pivot tables default to Wizard."
        ],
        "entry_type": "table_node",
        "families": [
          "table_pivot_js"
        ],
        "generator": "generate_editor_bundle",
        "known_limits": [
          "Reserved for specialized grouped or pinned JavaScript table semantics."
        ],
        "methods": {
          "create": "createEditorChart",
          "read": "getEditorChart",
          "update": "updateEditorChart"
        },
        "route": "editor_table"
      },
      {
        "do_not_change_runtime_contract": [
          "Keep Markdown on its dedicated Editor route."
        ],
        "entry_type": "markdown_node",
        "families": [
          "md_methodology_block",
          "md_section_header",
          "md_dashboard_owner",
          "md_contact_block",
          "md_requirements_link_block",
          "md_source_notes"
        ],
        "generator": "generate_editor_bundle",
        "known_limits": [
          "Text-only support blocks."
        ],
        "methods": {
          "create": "createEditorChart",
          "read": "getEditorChart",
          "update": "updateEditorChart"
        },
        "route": "editor_markdown"
      },
      {
        "do_not_change_runtime_contract": [
          "Keep controls separate from chart-body HTML."
        ],
        "entry_type": "control_node",
        "families": [
          "single_select_dropdown",
          "multi_select_dropdown",
          "search_selector",
          "date_range_selector",
          "selector_family_static",
          "selector_family_dynamic"
        ],
        "generator": "generate_editor_bundle",
        "known_limits": [
          "Controls require dashboard relation wiring."
        ],
        "methods": {
          "create": "createEditorChart",
          "read": "getEditorChart",
          "update": "updateEditorChart"
        },
        "route": "editor_js_control"
      },
      {
        "do_not_change_runtime_contract": [
          "Require explicit-user-request provenance and explicit payload or fresh saved seed."
        ],
        "entry_type": "ql_chart",
        "families": [
          "ql_explicit"
        ],
        "generator": "explicit_payload_fixture",
        "known_limits": [
          "No generation from a general prompt; delete remains closed."
        ],
        "methods": {
          "create": "createQLChart",
          "read": "getQLChart",
          "update": "updateQLChart"
        },
        "route": "ql_explicit"
      }
    ],
    "unsupported": [
      {
        "reason": "No maintained creation route.",
        "route": "regular_editor_chart"
      },
      {
        "reason": "No maintained creation route.",
        "route": "gravity_ui_charts"
      }
    ]
  },
